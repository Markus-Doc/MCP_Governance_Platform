                "conditions": [{"leftValue": "={{ $json.pre_approval_status }}", "rightValue": "new", "operator": {"type": "string", "operation": "equals"}}],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "new"
            }
          ]
        },

              "conditions": {
                "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 1},
                "conditions": [{"leftValue": "={{ $json.pre_approval_status }}", "rightValue": "pre_approved", "operator": {"type": "string", "operation": "equals"}}],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "pre_approved"
